{
	"name": "@harperfast/cortex-client",
	"version": "1.0.0",
	"description": "Lightweight HTTP-only TypeScript client for Harper Cortex — no runtime, no embeddings, just fetch + auth",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc && npm run build:cjs",
		"build:cjs": "esbuild dist/index.js --bundle --platform=node --format=cjs --outfile=dist/index.cjs && tsc --declaration",
		"dev": "tsc --watch",
		"test": "vitest run",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest --coverage",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"harper",
		"cortex",
		"memory",
		"synapse",
		"semantic-search",
		"vector-search",
		"http-client",
		"typescript"
	],
	"author": "Harper Cloud",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/HarperFast/Cortex.git",
		"directory": "packages/cortex-client"
	},
	"devDependencies": {
		"@types/node": "^20.10.0",
		"esbuild": "^0.19.0"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
