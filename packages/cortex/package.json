{
	"name": "@harperfast/cortex",
	"version": "2.0.0",
	"description": "Open-source AI memory system powered by Harper Fabric. Clone, configure, deploy.",
	"type": "module",
	"main": "resources.js",
	"bin": {
		"synapse": "./bin/synapse.js"
	},
	"license": "MIT",
	"files": [
		"resources.js",
		"resources/",
		"bin/",
		"schema.graphql",
		"config.yaml"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/HarperFast/Cortex.git",
		"directory": "packages/cortex"
	},
	"scripts": {
		"start": "harper run .",
		"dev": "harper dev .",
		"deploy": "npx -y dotenv-cli -- harper deploy . restart=rolling replicated=true",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.39.0",
		"@huggingface/transformers": "^3.8.1"
	},
	"devDependencies": {
		"harper": "^5.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
