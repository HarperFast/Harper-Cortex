# =============================================================================
# Cortex - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Harper Fabric Cluster ---
# Create a free cluster at https://harper.fast/start
CLI_TARGET=https://your-cluster.your-org.harperfabric.com
CLI_TARGET_USERNAME=your_admin_username
CLI_TARGET_PASSWORD=your_admin_password

# --- Classification Provider (optional) ---
# Classification categorizes memories (decision, action_item, knowledge, etc.).
# If no provider is configured, memories are stored with classification: null.
#
# Supported providers: anthropic (default), openai, google, ollama, openai-compatible, local
# CLASSIFICATION_PROVIDER=anthropic
# CLASSIFICATION_API_KEY=sk-ant-xxxxx       # Falls back to ANTHROPIC_API_KEY for Anthropic
# CLASSIFICATION_MODEL=claude-haiku-3-5-20241022  # Optional, defaults vary by provider
# CLASSIFICATION_BASE_URL=                  # Required for ollama/openai-compatible

# --- Anthropic Claude API (legacy / fallback for classification) ---
# Get your API key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Embeddings ---
# Embeddings are generated locally using ONNX (@huggingface/transformers, all-MiniLM-L6-v2).
# No API key needed — runs in-process on first call (downloads ~23MB model once).
# EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2  # Change to use a different HuggingFace model

# --- Namespace Enforcement (optional) ---
# Set to true to require agentId on all search/count requests (multi-tenant mode)
# REQUIRE_AGENT_NAMESPACE=false

# --- Slack (for webhook ingestion) ---
# Create a Slack app at https://api.slack.com/apps
# See docs/slack-app-setup.md for step-by-step instructions
SLACK_SIGNING_SECRET=xxxxx
SLACK_BOT_TOKEN=xoxb-xxxxx

# --- Synapse CLI (for context broker commands) ---
# See docs/synapse-design.md for usage instructions
SYNAPSE_ENDPOINT=https://your-cluster.your-org.harperfabric.com
SYNAPSE_PROJECT=your-project-name
SYNAPSE_AUTH=Basic dXNlcjpwYXNz
